+class EMA(nn.Module):
+    """Efficient multi-scale attention for feature recalibration."""
+
+    def __init__(self, channels: int, factor: int = 32):
+        """Initialize EMA with grouped spatial and channel interactions."""
+        super().__init__()
+        if channels % factor:
+            raise ValueError(f"channels ({channels}) must be divisible by factor ({factor})")
+        self.groups = factor
+        channels_per_group = channels // factor
+        self.softmax = nn.Softmax(dim=-1)
+        self.agp = nn.AdaptiveAvgPool2d((1, 1))
+        self.pool_h = nn.AdaptiveAvgPool2d((None, 1))
+        self.pool_w = nn.AdaptiveAvgPool2d((1, None))
+        self.gn = nn.GroupNorm(channels_per_group, channels_per_group)
+        self.conv1x1 = nn.Conv2d(channels_per_group, channels_per_group, 1, bias=True)
+        self.conv3x3 = nn.Conv2d(channels_per_group, channels_per_group, 3, padding=1, bias=True)
+
+    def forward(self, x: torch.Tensor) -> torch.Tensor:
+        """Apply efficient multi-scale attention."""
+        batch, channels, height, width = x.shape
+        groups = self.groups
+        channels_per_group = channels // groups
+        group_x = x.reshape(batch * groups, channels_per_group, height, width)
+        x_h = self.pool_h(group_x)
+        x_w = self.pool_w(group_x).permute(0, 1, 3, 2)
+        hw = self.conv1x1(torch.cat([x_h, x_w], dim=2))
+        x_h, x_w = torch.split(hw, [height, width], dim=2)
+        x1 = self.gn(group_x * x_h.sigmoid() * x_w.permute(0, 1, 3, 2).sigmoid())
+        x2 = self.conv3x3(group_x)
+        x11 = self.softmax(self.agp(x1).reshape(batch * groups, 1, channels_per_group))
+        x12 = x2.reshape(batch * groups, channels_per_group, -1)
+        x21 = self.softmax(self.agp(x2).reshape(batch * groups, 1, channels_per_group))
+        x22 = x1.reshape(batch * groups, channels_per_group, -1)
+        weights = (torch.matmul(x11, x12) + torch.matmul(x21, x22)).reshape(batch * groups, 1, height, width)
+        return (group_x * weights.sigmoid()).reshape(batch, channels, height, width)
+
+
+class ECA(nn.Module):
+    """Efficient channel attention."""
+
+    def __init__(self, channels: int, kernel_size: int = 3):
+        """Initialize ECA with a one-dimensional channel convolution."""
+        super().__init__()
+        self.avg_pool = nn.AdaptiveAvgPool2d(1)
+        self.conv = nn.Conv1d(1, 1, kernel_size=kernel_size, padding=(kernel_size - 1) // 2, bias=False)
+        self.sigmoid = nn.Sigmoid()
+
+    def forward(self, x: torch.Tensor) -> torch.Tensor:
+        """Apply efficient channel attention."""
+        y = self.avg_pool(x).squeeze(-1).transpose(-1, -2)
+        y = self.conv(y).transpose(-1, -2).unsqueeze(-1)
+        return x * self.sigmoid(y)
+
+
+def normal_init(module: nn.Module, mean: float = 0.0, std: float = 1.0, bias: float = 0.0) -> None:
+    """Initialize module weights from a normal distribution."""
+    if hasattr(module, "weight") and module.weight is not None:
+        nn.init.normal_(module.weight, mean, std)
+    if hasattr(module, "bias") and module.bias is not None:
+        nn.init.constant_(module.bias, bias)
+
+
+def constant_init(module: nn.Module, value: float, bias: float = 0.0) -> None:
+    """Initialize module weights to a constant value."""
+    if hasattr(module, "weight") and module.weight is not None:
+        nn.init.constant_(module.weight, value)
+    if hasattr(module, "bias") and module.bias is not None:
+        nn.init.constant_(module.bias, bias)
+
