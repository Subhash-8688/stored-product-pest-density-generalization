+class DySample(nn.Module):
+    """Dynamic upsampling by learned sampling offsets."""
+
+    def __init__(self, in_channels: int, scale: int = 2, style: str = "lp", groups: int = 4, dyscope: bool = False):
+        """Initialize DySample."""
+        super().__init__()
+        if style not in {"lp", "pl"}:
+            raise ValueError(f"unsupported DySample style: {style}")
+        if style == "pl" and (in_channels < scale**2 or in_channels % scale**2):
+            raise ValueError("pl style requires channels divisible by scale squared")
+        if in_channels < groups or in_channels % groups:
+            raise ValueError("input channels must be divisible by groups")
+        self.scale = scale
+        self.style = style
+        self.groups = groups
+        offset_channels = 2 * groups if style == "pl" else 2 * groups * scale**2
+        offset_in_channels = in_channels // scale**2 if style == "pl" else in_channels
+        self.offset = nn.Conv2d(offset_in_channels, offset_channels, 1)
+        normal_init(self.offset, std=0.001)
+        if dyscope:
+            self.scope = nn.Conv2d(offset_in_channels, offset_channels, 1, bias=False)
+            constant_init(self.scope, value=0.0)
+        self.register_buffer("init_pos", self._init_pos())
+
+    def _init_pos(self) -> torch.Tensor:
+        """Create the regular initial sampling grid."""
+        h = torch.arange((-self.scale + 1) / 2, (self.scale - 1) / 2 + 1) / self.scale
+        return torch.stack(torch.meshgrid(h, h, indexing="ij")).transpose(1, 2).repeat(1, self.groups, 1).reshape(1, -1, 1, 1)
+
+    def sample(self, x: torch.Tensor, offset: torch.Tensor) -> torch.Tensor:
+        """Sample the input feature map at dynamically predicted offsets."""
+        batch, _, height, width = offset.shape
+        offset = offset.view(batch, 2, -1, height, width)
+        coords_h = torch.arange(height, device=x.device, dtype=x.dtype) + 0.5
+        coords_w = torch.arange(width, device=x.device, dtype=x.dtype) + 0.5
+        coords = torch.stack(torch.meshgrid(coords_w, coords_h, indexing="ij")).transpose(1, 2).unsqueeze(1).unsqueeze(0)
+        normalizer = torch.tensor([width, height], dtype=x.dtype, device=x.device).view(1, 2, 1, 1, 1)
+        coords = 2 * (coords + offset) / normalizer - 1
+        coords = (
+            F.pixel_shuffle(coords.view(batch, -1, height, width), self.scale)
+            .view(batch, 2, -1, self.scale * height, self.scale * width)
+            .permute(0, 2, 3, 4, 1)
+            .contiguous()
+            .flatten(0, 1)
+        )
+        return F.grid_sample(
+            x.reshape(batch * self.groups, -1, height, width),
+            coords,
+            mode="bilinear",
+            align_corners=False,
+            padding_mode="border",
+        ).view(batch, -1, self.scale * height, self.scale * width)
+
+    def forward_lp(self, x: torch.Tensor) -> torch.Tensor:
+        """Upsample using offsets predicted before pixel shuffling."""
+        offset = (
+            self.offset(x) * self.scope(x).sigmoid() * 0.5 + self.init_pos
+            if hasattr(self, "scope")
+            else self.offset(x) * 0.25 + self.init_pos
+        )
+        return self.sample(x, offset)
+
+    def forward_pl(self, x: torch.Tensor) -> torch.Tensor:
+        """Upsample using offsets predicted after pixel shuffling."""
+        x_ = F.pixel_shuffle(x, self.scale)
+        offset = (
+            F.pixel_unshuffle(self.offset(x_) * self.scope(x_).sigmoid(), self.scale) * 0.5 + self.init_pos
+            if hasattr(self, "scope")
+            else F.pixel_unshuffle(self.offset(x_), self.scale) * 0.25 + self.init_pos
+        )
+        return self.sample(x, offset)
+
+    def forward(self, x: torch.Tensor) -> torch.Tensor:
+        """Apply dynamic upsampling."""
+        return self.forward_pl(x) if self.style == "pl" else self.forward_lp(x)
